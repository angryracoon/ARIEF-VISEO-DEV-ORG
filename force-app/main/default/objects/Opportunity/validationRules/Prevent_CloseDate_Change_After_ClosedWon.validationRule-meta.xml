<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Prevent_CloseDate_Change_After_ClosedWon</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(StageName, "Closed Won"),
  ISCHANGED(CloseDate),
  $Profile.Name != "System Administrator"
)</errorConditionFormula>
    <errorMessage>Close Date cannot be modified after the Opportunity is Closed Won.</errorMessage>
</ValidationRule>
