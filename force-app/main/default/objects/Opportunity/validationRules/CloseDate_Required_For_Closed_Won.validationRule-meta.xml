<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CloseDate_Required_For_Closed_Won</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(StageName, &quot;Closed Won&quot;),
  ISBLANK(CloseDate)
)</errorConditionFormula>
    <errorMessage>Close Date is required when the Opportunity Stage is Closed Won.</errorMessage>
</ValidationRule>
