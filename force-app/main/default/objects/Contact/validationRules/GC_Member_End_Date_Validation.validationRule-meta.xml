<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>GC_Member_End_Date_Validation</fullName>
    <active>true</active>
    <description>End date cannot before start date</description>
    <errorConditionFormula>GC_Membership_End_Date__c &lt; GC_Membership_Start_Date__c</errorConditionFormula>
    <errorDisplayField>GC_Membership_End_Date__c</errorDisplayField>
    <errorMessage>Membership End Date cannot be before the Start Date.</errorMessage>
</ValidationRule>
