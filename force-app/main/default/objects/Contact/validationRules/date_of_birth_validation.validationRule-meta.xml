<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>date_of_birth_validation</fullName>
    <active>true</active>
    <description>Cannot set future date for birthdate</description>
    <errorConditionFormula>Birthdate &gt; TODAY()</errorConditionFormula>
    <errorDisplayField>Birthdate</errorDisplayField>
    <errorMessage>Cannot set future date as Date of Birth.</errorMessage>
</ValidationRule>
