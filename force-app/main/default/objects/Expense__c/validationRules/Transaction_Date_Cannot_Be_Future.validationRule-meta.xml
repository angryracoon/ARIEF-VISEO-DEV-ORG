<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Transaction_Date_Cannot_Be_Future</fullName>
    <active>true</active>
    <errorConditionFormula>Transaction_Date__c &gt; TODAY()</errorConditionFormula>
    <errorDisplayField>Transaction_Date__c</errorDisplayField>
    <errorMessage>Transaction Date cannot be in the future.</errorMessage>
</ValidationRule>
