<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>pending_order_need_products</fullName>
    <active>true</active>
    <errorConditionFormula>And(Order_Product_Count__c &lt;= 0,ISPICKVAL(Status ,&apos;Pending&apos;) )</errorConditionFormula>
    <errorMessage>An order must have at least one product.</errorMessage>
</ValidationRule>
