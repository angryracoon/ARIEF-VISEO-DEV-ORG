<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <description>After-save record-triggered flow on Project_Task__c. Entry fires when Reminder_Date__c is set or changed. Scheduled path calls the send-reminder sub-flow 3 days before Reminder_Date__c.</description>
    <interviewLabel>Project Task After Save {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Project Task After Save</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>56</locationX>
        <locationY>0</locationY>
        <filterLogic>1 AND 2</filterLogic>
        <filters>
            <field>Reminder_Date__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Reminder_Date__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Project_Task__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <scheduledPaths>
            <name>Three_Days_Before_Reminder</name>
            <connector>
                <targetReference>Call_Send_Reminder_Subflow</targetReference>
            </connector>
            <label>3 Days Before Reminder</label>
            <offsetNumber>-3</offsetNumber>
            <offsetUnit>Days</offsetUnit>
            <timeSource>Reminder_Date__c</timeSource>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <subflows>
        <name>Call_Send_Reminder_Subflow</name>
        <label>Call Send Reminder Subflow</label>
        <locationX>176</locationX>
        <locationY>158</locationY>
        <flowName>Project_Task_Reminder_Notification_Subflow</flowName>
        <inputAssignments>
            <name>recordId</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>ownerId</name>
            <value>
                <elementReference>$Record.OwnerId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>taskName</name>
            <value>
                <elementReference>$Record.Task_Name__c</elementReference>
            </value>
        </inputAssignments>
    </subflows>
</Flow>
